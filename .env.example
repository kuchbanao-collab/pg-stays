# NEXUS Platform — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# ============================================================
# SUPABASE (get from supabase.com → your project → Settings → API)
# ============================================================
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# For agents that need admin access (optional, use service_role key):
# SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ============================================================
# ANTHROPIC CLAUDE API (get from console.anthropic.com)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ============================================================
# OPTIONAL: WhatsApp / Twilio (for sending actual nudge messages)
# ============================================================
# TWILIO_SID=your_twilio_sid
# TWILIO_TOKEN=your_twilio_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ============================================================
# OPTIONAL: Payment Gateway (for collecting commissions)
# ============================================================
# RAZORPAY_KEY_ID=rzp_live_xxxxx
# RAZORPAY_KEY_SECRET=your_razorpay_secret

# ============================================================
# OPTIONAL: Email notifications (Resend.com — free tier)
# ============================================================
# RESEND_API_KEY=re_your_key_here
# FROM_EMAIL=noreply@nexus-indore.com
